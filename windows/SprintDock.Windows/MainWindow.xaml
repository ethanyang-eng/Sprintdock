<Window x:Class="SprintDock.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Sprint Dock"
        Width="1220" Height="780" MinWidth="980" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#F7F9FD" FontFamily="Segoe UI" Foreground="#101828">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="7" CornerRadius="8" GlassFrameThickness="0" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <SolidColorBrush x:Key="Ink" Color="#101828" />
    <SolidColorBrush x:Key="Muted" Color="#667085" />
    <SolidColorBrush x:Key="Blue" Color="#2563EB" />
    <SolidColorBrush x:Key="Line" Color="#E4E8F0" />
    <SolidColorBrush x:Key="Panel" Color="#FAFFFFFF" />
    <SolidColorBrush x:Key="SoftBlue" Color="#EEF4FF" />

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Panel}" />
      <Setter Property="BorderBrush" Value="{StaticResource Line}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource Blue}" />
      <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.88" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource Line}" />
    </Style>

    <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource Blue}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="9,7" />
    </Style>

    <Style x:Key="RailButton" TargetType="Button" BasedOn="{StaticResource QuietButton}">
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,2" />
    </Style>

    <Style x:Key="WindowButton" TargetType="Button">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="5">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#E7EAF0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FieldTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource Line}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="11,9" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CaretBrush" Value="{StaticResource Blue}" />
    </Style>

    <Style x:Key="Eyebrow" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <DataTemplate x:Key="TaskTemplate">
      <Border Margin="0,0,0,8" Padding="10" BorderThickness="1" CornerRadius="6">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                <Setter Property="Background" Value="#F0F5FF" />
                <Setter Property="BorderBrush" Value="#AFC6FF" />
              </DataTrigger>
              <DataTrigger Binding="{Binding IsDone}" Value="True">
                <Setter Property="Opacity" Value="0.58" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border x:Name="TaskDot" Width="8" Height="8" CornerRadius="4" Background="#D0D5DD" Margin="0,0,10,0" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" LostKeyboardFocus="TaskTitle_LostKeyboardFocus"
                   BorderThickness="0" Background="Transparent" Padding="2" VerticalContentAlignment="Center" />
          <Button Grid.Column="2" Content="Focus" Style="{StaticResource QuietButton}" Click="FocusTask_Click" />
          <Button Grid.Column="3" Content="Done" Style="{StaticResource QuietButton}" Click="CompleteTask_Click" />
          <Button Grid.Column="4" Content="..." Style="{StaticResource QuietButton}" ToolTip="Task options" Click="TaskMore_Click">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Move up" Click="MoveTaskUp_Click" />
                <MenuItem Header="Move down" Click="MoveTaskDown_Click" />
                <Separator />
                <MenuItem Header="Delete" Click="DeleteTask_Click" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="DraftTaskTemplate">
      <Border Margin="0,0,0,8" Padding="9" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="2" />
          <Button Grid.Column="1" Content="Remove" Style="{StaticResource QuietButton}" Click="DeleteDraftTask_Click" />
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="BlockerTemplate">
      <Border Margin="0,0,0,8" Padding="11" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" LostKeyboardFocus="BlockerText_LostKeyboardFocus"
                   BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" />
          <Button Grid.Column="1" Content="Resolve" Style="{StaticResource QuietButton}" Click="ResolveBlocker_Click" />
          <Button Grid.Column="2" Content="Delete" Style="{StaticResource QuietButton}" Click="DeleteBlocker_Click" />
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="ChecklistTemplate">
      <CheckBox Content="{Binding Title}" IsChecked="{Binding IsDone, Mode=TwoWay}" Checked="Checklist_Changed" Unchecked="Checklist_Changed"
                Margin="2,7" FontSize="14" />
    </DataTemplate>

    <DataTemplate x:Key="ActivityTemplate">
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Width="6" Height="6" CornerRadius="3" Background="{StaticResource Blue}" VerticalAlignment="Top" Margin="0,7,0,0" />
        <StackPanel Grid.Column="1" Margin="8,0,0,0">
          <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
          <TextBlock Text="{Binding DisplayTime}" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,3,0,0" />
        </StackPanel>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FBFCFF" Offset="0" />
        <GradientStop Color="#F4F7FD" Offset="0.62" />
        <GradientStop Color="#FFF7FB" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>
    <Grid.RowDefinitions>
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#F7F9FDEB" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
          <Border Width="28" Height="28" CornerRadius="8">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3478F6" Offset="0" />
                <GradientStop Color="#6366F1" Offset="0.68" />
                <GradientStop Color="#EC4899" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="SD" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="Sprint Dock" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
          <TextBlock Text="  Windows" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button Content="-" Style="{StaticResource WindowButton}" Click="Minimize_Click" />
          <Button Content="□" Style="{StaticResource WindowButton}" Click="Maximize_Click" />
          <Button Content="×" Style="{StaticResource WindowButton}" Click="Close_Click" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="WorkspaceHost" Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="158" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="#F7F9FDE8" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
        <Grid Margin="14">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <StackPanel>
            <TextBlock Text="COMMAND STRIP" Style="{StaticResource Eyebrow}" Margin="10,8,0,10" />
            <Button Content="Focus" Style="{StaticResource RailButton}" Click="FocusRail_Click" ToolTip="Return to the focus workspace" />
            <Button Content="Plan" Style="{StaticResource RailButton}" Click="PlanRail_Click" ToolTip="Open tasks" />
            <Button Content="Blockers" Style="{StaticResource RailButton}" Click="BlockersRail_Click" ToolTip="Open blockers" />
            <Button Content="Notes" Style="{StaticResource RailButton}" Click="NotesRail_Click" ToolTip="Open notes" />
            <Button Content="History" Style="{StaticResource RailButton}" Click="HistoryRail_Click" ToolTip="Open activity history" />
          </StackPanel>
          <StackPanel Grid.Row="2">
            <Border Background="#EEF4FF" CornerRadius="6" Padding="10" Margin="0,0,0,8">
              <StackPanel>
                <TextBlock Text="PROGRESS" Style="{StaticResource Eyebrow}" />
                <TextBlock x:Name="RailProgressText" Text="0 of 0 steps" FontWeight="SemiBold" Margin="0,4,0,0" />
              </StackPanel>
            </Border>
            <Button Content="New sprint" Style="{StaticResource RailButton}" Click="NewSprint_Click" />
          </StackPanel>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,36" MaxWidth="1040">
          <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="TODAY'S GOAL" Style="{StaticResource Eyebrow}" />
              <TextBox x:Name="GoalWorkspaceText" TextChanged="WorkspaceText_Changed" BorderThickness="0" Background="Transparent"
                       FontSize="32" FontWeight="Bold" Padding="0,5,0,2" TextWrapping="Wrap" AcceptsReturn="True" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Margin="24,0,0,0">
              <Border Background="#EAF2FF" CornerRadius="10" Padding="10,5" HorizontalAlignment="Right">
                <TextBlock Text="Active" Foreground="{StaticResource Blue}" FontWeight="SemiBold" FontSize="12" />
              </Border>
              <TextBlock x:Name="HeaderProgressText" Text="0 of 0 steps" FontWeight="SemiBold" Margin="0,9,0,0" HorizontalAlignment="Right" />
            </StackPanel>
          </Grid>

          <ProgressBar x:Name="SprintProgress" Minimum="0" Maximum="100" Height="5" BorderThickness="0" Foreground="{StaticResource Blue}" Background="#E4E8F0" Margin="0,0,0,24" />

          <Border Style="{StaticResource PanelBorder}" Padding="0">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
              <Grid Margin="28,26">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,28,0">
                  <TextBlock Text="NOW" Style="{StaticResource Eyebrow}" />
                  <TextBlock x:Name="CurrentTaskText" Text="Choose your next step" FontSize="34" FontWeight="Bold" TextWrapping="Wrap" Margin="0,14,0,16" />
                  <TextBlock Text="FINISH CRITERIA" Style="{StaticResource Eyebrow}" Margin="0,0,0,6" />
                  <TextBox x:Name="FinishLineText" Style="{StaticResource FieldTextBox}" TextChanged="WorkspaceText_Changed"
                           TextWrapping="Wrap" AcceptsReturn="True" MinHeight="62" />
                  <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="Complete step" Style="{StaticResource PrimaryButton}" Click="CompleteCurrent_Click" />
                    <Button Content="Replan locally" Style="{StaticResource SecondaryButton}" Click="Replan_Click" Margin="9,0,0,0" />
                  </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource Line}" />

                <StackPanel Grid.Column="2" Margin="28,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="FOCUS" Style="{StaticResource Eyebrow}" HorizontalAlignment="Center" />
                  <TextBlock x:Name="TimerText" Text="25:00" FontSize="64" FontWeight="Bold" Margin="0,12,0,12" HorizontalAlignment="Center" />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="TimerStartButton" Content="Start" Style="{StaticResource PrimaryButton}" Click="TimerStart_Click" />
                    <Button Content="Reset" Style="{StaticResource SecondaryButton}" Click="TimerReset_Click" Margin="8,0,0,0" />
                    <Button Content="+5" Style="{StaticResource SecondaryButton}" Click="TimerExtend_Click" Margin="8,0,0,0" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                    <TextBlock Text="Duration" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="TimerMinutesBox" Width="52" Style="{StaticResource FieldTextBox}" Padding="7,5" HorizontalContentAlignment="Center" />
                    <TextBlock Text="min" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="7,0" />
                    <Button Content="Apply" Style="{StaticResource QuietButton}" Click="ApplyDuration_Click" />
                  </StackPanel>
                </StackPanel>
              </Grid>

              <Border Grid.Row="1" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,1" Background="#F5F8FF" Padding="28,17">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="NEXT ACTION" Style="{StaticResource Eyebrow}" VerticalAlignment="Center" Margin="0,0,16,0" />
                  <TextBox x:Name="NextActionText" Grid.Column="1" TextChanged="WorkspaceText_Changed" BorderThickness="0" Background="Transparent" FontWeight="SemiBold" />
                  <Button Grid.Column="2" Content="Open plan" Style="{StaticResource QuietButton}" Click="PlanRail_Click" />
                </Grid>
              </Border>

              <Grid Grid.Row="2" Margin="28,15">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StepsSummary" Text="0/0  Steps" Foreground="{StaticResource Muted}" Margin="0,0,24,0" />
                <TextBlock x:Name="BlockersSummary" Grid.Column="1" Text="0  Blockers" Foreground="{StaticResource Muted}" Margin="0,0,24,0" />
                <TextBlock x:Name="ReadySummary" Grid.Column="2" Text="0%  Ready" Foreground="{StaticResource Muted}" Margin="0,0,24,0" />
                <TextBlock x:Name="SessionsSummary" Grid.Column="3" Text="0  Sessions" Foreground="{StaticResource Muted}" />
                <Button Grid.Column="5" Content="Open Dock" Style="{StaticResource QuietButton}" Click="PlanRail_Click" />
              </Grid>
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border x:Name="DockPanel" Grid.Column="2" Width="430" Background="#FCFDFF" BorderBrush="{StaticResource Line}" BorderThickness="1,0,0,0" Visibility="Collapsed">
        <Grid Margin="22">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="DOCK" Style="{StaticResource Eyebrow}" />
              <TextBlock x:Name="DockTitle" Text="Plan" FontSize="25" FontWeight="Bold" Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="Close" Style="{StaticResource QuietButton}" Click="CloseDock_Click" VerticalAlignment="Top" />
          </Grid>

          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,16">
            <Button Content="Plan" Style="{StaticResource SecondaryButton}" Click="PlanRail_Click" Padding="10,7" />
            <Button Content="Blockers" Style="{StaticResource SecondaryButton}" Click="BlockersRail_Click" Padding="10,7" Margin="6,0,0,0" />
            <Button Content="Checklist" Style="{StaticResource SecondaryButton}" Click="ChecklistRail_Click" Padding="10,7" Margin="6,0,0,0" />
            <Button Content="Notes" Style="{StaticResource SecondaryButton}" Click="NotesRail_Click" Padding="10,7" Margin="6,0,0,0" />
            <Button Content="Log" Style="{StaticResource SecondaryButton}" Click="HistoryRail_Click" Padding="10,7" Margin="6,0,0,0" />
          </StackPanel>

          <Grid Grid.Row="2">
            <ScrollViewer x:Name="PlanDock" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <TextBlock Text="The focused step stays highlighted. Edit any title directly." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />
                <ItemsControl x:Name="TaskItems" ItemTemplate="{StaticResource TaskTemplate}" />
                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="NewTaskBox" Style="{StaticResource FieldTextBox}" ToolTip="New task title" KeyDown="NewTaskBox_KeyDown" />
                  <Button Grid.Column="1" Content="Add task" Style="{StaticResource PrimaryButton}" Click="AddTask_Click" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="BlockersDock" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <TextBlock Text="Capture anything stopping the current step, then resolve it when the path is clear." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />
                <ItemsControl x:Name="BlockerItems" ItemTemplate="{StaticResource BlockerTemplate}" />
                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="NewBlockerBox" Style="{StaticResource FieldTextBox}" ToolTip="New blocker" KeyDown="NewBlockerBox_KeyDown" />
                  <Button Grid.Column="1" Content="Add" Style="{StaticResource PrimaryButton}" Click="AddBlocker_Click" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ChecklistDock" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <TextBlock Text="A short finish check keeps the sprint honest without turning it into a project board." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />
                <ItemsControl x:Name="ChecklistItems" ItemTemplate="{StaticResource ChecklistTemplate}" />
              </StackPanel>
            </ScrollViewer>

            <Grid x:Name="NotesDock" Visibility="Collapsed">
              <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
              <TextBlock Text="Notes save automatically on this PC." Foreground="{StaticResource Muted}" Margin="0,0,0,12" />
              <TextBox x:Name="NotesText" Grid.Row="1" Style="{StaticResource FieldTextBox}" TextChanged="NotesText_Changed"
                       AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" />
            </Grid>

            <ScrollViewer x:Name="HistoryDock" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <TextBlock Text="Completed steps, timer sessions, blockers, and plan changes." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />
                <ItemsControl x:Name="ActivityItems" ItemTemplate="{StaticResource ActivityTemplate}" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Grid x:Name="OnboardingOverlay" Grid.Row="1">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#F8FAFF" Offset="0" />
          <GradientStop Color="#EEF4FF" Offset="0.65" />
          <GradientStop Color="#FFF3FA" Offset="1" />
        </LinearGradientBrush>
      </Grid.Background>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="42" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900">
          <Border Style="{StaticResource PanelBorder}" Padding="34" MinWidth="760">
            <Grid>
              <StackPanel x:Name="GoalEntryPanel">
                <TextBlock Text="SPRINT DOCK FOR WINDOWS" Foreground="{StaticResource Blue}" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="What do you want to finish today?" FontSize="38" FontWeight="Bold" Margin="0,9,0,8" />
                <TextBlock Text="Turn one outcome into a small, editable sprint. Everything stays on this PC." Foreground="{StaticResource Muted}" FontSize="16" />

                <Border x:Name="ContinueCard" Background="#EEF4FF" CornerRadius="7" Padding="16" Margin="0,24,0,0" Visibility="Collapsed">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="Continue your current sprint" FontWeight="SemiBold" />
                      <TextBlock x:Name="ContinueGoalText" Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Continue" Style="{StaticResource PrimaryButton}" Click="ContinueSprint_Click" Margin="16,0,0,0" />
                  </Grid>
                </Border>

                <TextBlock Text="TODAY'S FINISH LINE" Style="{StaticResource Eyebrow}" Margin="0,26,0,7" />
                <TextBox x:Name="GoalInput" Style="{StaticResource FieldTextBox}" FontSize="22" FontWeight="SemiBold" MinHeight="52"
                         TextWrapping="Wrap" AcceptsReturn="True" ToolTip="The outcome you want to finish" />
                <Expander Header="Add details (optional)" Margin="0,14,0,0">
                  <TextBox x:Name="DetailsInput" Style="{StaticResource FieldTextBox}" Margin="0,10,0,0" MinHeight="70"
                           TextWrapping="Wrap" AcceptsReturn="True" ToolTip="Constraints or what done should look like" />
                </Expander>
                <Grid Margin="0,22,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Focus length" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
                    <ComboBox x:Name="FocusLengthCombo" Width="130" Margin="10,0,0,0" SelectedIndex="1">
                      <ComboBoxItem Content="15 minutes" Tag="15" />
                      <ComboBoxItem Content="25 minutes" Tag="25" />
                      <ComboBoxItem Content="45 minutes" Tag="45" />
                      <ComboBoxItem Content="60 minutes" Tag="60" />
                    </ComboBox>
                  </StackPanel>
                  <Button Grid.Column="1" Content="Build my plan" Style="{StaticResource PrimaryButton}" Click="BuildPlan_Click" />
                </Grid>
              </StackPanel>

              <StackPanel x:Name="PlanPreviewPanel" Visibility="Collapsed">
                <TextBlock Text="YOUR SPRINT IS READY" Foreground="{StaticResource Blue}" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="Review the plan before you begin." FontSize="36" FontWeight="Bold" Margin="0,9,0,8" />
                <TextBlock Text="Every field is editable. The first step becomes your current focus." Foreground="{StaticResource Muted}" FontSize="16" />
                <Grid Margin="0,26,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="0.8*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="GOAL" Style="{StaticResource Eyebrow}" />
                    <TextBox x:Name="PreviewGoalText" BorderThickness="0" Background="Transparent" FontSize="23" FontWeight="Bold"
                             TextWrapping="Wrap" AcceptsReturn="True" Padding="0,7" />
                    <TextBlock Text="DONE LOOKS LIKE" Style="{StaticResource Eyebrow}" Margin="0,14,0,7" />
                    <TextBox x:Name="PreviewFinishText" Style="{StaticResource FieldTextBox}" MinHeight="82" TextWrapping="Wrap" AcceptsReturn="True" />
                  </StackPanel>
                  <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Background="#F8FAFF" Padding="16">
                    <StackPanel>
                      <TextBlock Text="Plan" FontWeight="Bold" FontSize="18" />
                      <TextBlock Text="Edit a step directly or remove it." Foreground="{StaticResource Muted}" Margin="0,3,0,12" />
                      <ItemsControl x:Name="DraftTaskItems" ItemTemplate="{StaticResource DraftTaskTemplate}" />
                      <Button Content="Add step" Style="{StaticResource QuietButton}" Click="AddDraftTask_Click" HorizontalAlignment="Left" />
                    </StackPanel>
                  </Border>
                </Grid>
                <Grid Margin="0,24,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <Button Content="Back" Style="{StaticResource SecondaryButton}" Click="BackToGoal_Click" HorizontalAlignment="Left" />
                  <Button Grid.Column="1" Content="Rebuild plan" Style="{StaticResource SecondaryButton}" Click="RebuildPlan_Click" Margin="0,0,9,0" />
                  <Button Grid.Column="2" Content="Start sprint" Style="{StaticResource PrimaryButton}" Click="StartSprint_Click" />
                </Grid>
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Window>
